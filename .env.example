# ──────────────────────────────────────────────────────────────
# Environment Variables – copy this file to .env.local and fill in
# ──────────────────────────────────────────────────────────────

# ── AI Provider (pick ONE – priority order: Gemini → OpenAI → Groq) ──
#
# Option 1: Google Gemini (FREE, no billing required) ← RECOMMENDED
#   Get key at: https://aistudio.google.com  → "Get API key"
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option 2: OpenAI GPT-4o-mini (requires $5 minimum billing)
#   Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option 3: Groq (FREE – fast LLaMA 3 models)
#   Get key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email delivery via Resend (https://resend.com) – free tier available
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The clinic's receiving email for appointment / contact forms
CLINIC_EMAIL=info@brightsmileclinic.com

# Next.js public URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps Embed API key (optional – iframe embed works without one)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
